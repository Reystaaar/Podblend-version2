# ==========================================================
#  Podblend — Performance (cache + compression)
# ==========================================================

# ----- Compression (gzip / deflate) -----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ----- Brotli (si dispo sur l'hébergeur) -----
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript image/svg+xml application/json
</IfModule>

# ----- Cache navigateur (Expires) -----
<IfModule mod_expires.c>
    ExpiresActive On

    # Images & vidéos : 1 an
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType video/webm              "access plus 1 year"
    ExpiresByType video/mp4               "access plus 1 year"

    # CSS & JS : 1 an
    ExpiresByType text/css                "access plus 1 year"
    ExpiresByType application/javascript  "access plus 1 year"

    # Polices : 1 an
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType font/woff               "access plus 1 year"

    # HTML : court (contenu qui change)
    ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

# ----- Cache-Control headers -----
<IfModule mod_headers.c>
    # Assets immuables (images, vidéos, css, js, polices)
    <FilesMatch "\.(webp|png|jpe?g|svg|ico|webm|mp4|css|js|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # HTML : toujours revalider
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
</IfModule>
